<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.EnForma" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <item name="android:background">@color/primary</item>

    </style>

    <style name="Theme.EnForma" parent="Base.Theme.EnForma">
        <item name="android:navigationBarColor">@color/primaryDark</item>
    </style>

    <style name="title" parent="Base.Theme.EnForma">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:titleMarginTop">40dp</item>
        <item name="android:textColor">@color/primaryDark</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <style name="button" parent="Base.Theme.EnForma">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">40dp</item>
        <item name="android:background">@drawable/bt_round</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">20sp</item>
    </style>

</resources>